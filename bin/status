#!/usr/bin/env bash
# bin/status -- the single pane of glass. For every discovered job: schedule,
# runtime, whether launchd has it loaded, its last exit code, the last-success
# marker time, and a HEALTH check that the plist's referenced lib.sh + .autojob
# still exist (catches a moved checkout before launchd fails silently with 127).
#
# Usage: status   (no args)

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/lib.sh
source "$SCRIPT_DIR/lib.sh"

# Pull "last exit code = N" from `launchctl print`. Prints a status word.
launchd_state() {
  local label="$1" out
  out="$(launchctl print "$AUTO_GUI_DOMAIN/$label" 2>/dev/null)" || { echo "not-loaded"; return; }
  local exitcode
  exitcode="$(printf '%s\n' "$out" | sed -n 's/.*last exit code = \([0-9-]*\).*/\1/p' | head -1)"
  if [[ -z "$exitcode" ]]; then
    echo "loaded(norun)"
  elif [[ "$exitcode" == "0" ]]; then
    echo "loaded,exit0"
  else
    echo "loaded,EXIT$exitcode"
  fi
}

# Confirm the installed plist still points at a real lib.sh and a real .autojob.
# Prints "ok" or a specific BROKEN reason.
health() {
  local label="$1"
  local plist="$AUTO_LAUNCH_AGENTS/$label.plist"
  [[ -f "$plist" ]] || { echo "BROKEN:no-plist"; return; }
  local lib job
  lib="$(sed -n 's|.*<string>\(.*/lib.sh\)</string>.*|\1|p' "$plist" | head -1)"
  job="$(sed -n 's|.*<string>\(.*\.autojob\)</string>.*|\1|p' "$plist" | head -1)"
  [[ -n "$lib" && -f "$lib" ]] || { echo "BROKEN:lib-missing"; return; }
  [[ -n "$job" && -f "$job" ]] || { echo "BROKEN:autojob-missing"; return; }
  echo "ok"
}

JOBFILES=()
while IFS= read -r line; do [[ -n "$line" ]] && JOBFILES+=("$line"); done < <(discover_jobs)

echo "registered roots:"
registered_roots | sed 's/^/  /'
[[ -n "$(registered_roots)" ]] || echo "  (none -- check registrations/ and that the sibling checkouts exist)"
echo

if [[ ${#JOBFILES[@]} -eq 0 ]]; then
  echo "automations: no *.autojob discovered under registered roots"
  exit 0
fi

printf '%-26s %-6s %-24s %-14s %-16s %s\n' "LABEL" "SCHED" "RUNTIME" "LAUNCHD" "HEALTH" "LAST-SUCCESS"
printf '%-26s %-6s %-24s %-14s %-16s %s\n' "-----" "-----" "-------" "-------" "------" "------------"
for jf in "${JOBFILES[@]}"; do
  if ! parse_job "$jf" 2>/dev/null; then
    printf '%-26s %s\n' "(invalid)" "$jf -- failed to parse"
    continue
  fi
  marker="$AUTO_LOG_BASE/$JOB_LABEL/$JOB_LABEL.last-success"
  if [[ -f "$marker" ]]; then last="$(cat "$marker")"; else last="never"; fi
  en=""; [[ "$JOB_ENABLED" != "true" ]] && en=" (ENABLED=$JOB_ENABLED)"
  rt="$JOB_RUNTIME"; [[ -n "$JOB_MODEL" ]] && rt="$JOB_RUNTIME($JOB_MODEL)"
  printf '%-26s %-6s %-24s %-14s %-16s %s\n' \
    "$JOB_LABEL" "$JOB_SCHEDULE" "$rt" "$(launchd_state "$JOB_LABEL")" "$(health "$JOB_LABEL")" "$last$en"
done
