#!/usr/bin/env bash
# bin/status -- the single pane of glass. For every discovered job: schedule,
# runtime, whether the scheduler has it loaded, its last exit code, the
# last-success marker time, and a HEALTH check that the installed unit's
# referenced lib.sh + .autojob still exist (catches a moved checkout before the
# scheduler fails silently). Backend-agnostic: launchd on macOS, systemd on Linux.
#
# Usage: status   (no args)

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/lib.sh
source "$SCRIPT_DIR/lib.sh"

JOBFILES=()
while IFS= read -r line; do [[ -n "$line" ]] && JOBFILES+=("$line"); done < <(discover_jobs)

echo "registered roots:"
registered_roots | sed 's/^/  /'
[[ -n "$(registered_roots)" ]] || echo "  (none -- check registrations/ and that the sibling checkouts exist)"
echo

if [[ ${#JOBFILES[@]} -eq 0 ]]; then
  echo "automations: no *.autojob discovered under registered roots"
  exit 0
fi

printf '%-26s %-6s %-24s %-14s %-16s %s\n' "LABEL" "SCHED" "RUNTIME" "SCHEDULER" "HEALTH" "LAST-SUCCESS"
printf '%-26s %-6s %-24s %-14s %-16s %s\n' "-----" "-----" "-------" "-------" "------" "------------"
for jf in "${JOBFILES[@]}"; do
  if ! parse_job "$jf" 2>/dev/null; then
    printf '%-26s %s\n' "(invalid)" "$jf -- failed to parse"
    continue
  fi
  marker="$AUTO_LOG_BASE/$JOB_LABEL/$JOB_LABEL.last-success"
  if [[ -f "$marker" ]]; then last="$(cat "$marker")"; else last="never"; fi
  en=""; [[ "$JOB_ENABLED" != "true" ]] && en=" (ENABLED=$JOB_ENABLED)"
  rt="$JOB_RUNTIME"; [[ -n "$JOB_MODEL" ]] && rt="$JOB_RUNTIME($JOB_MODEL)"
  printf '%-26s %-6s %-24s %-14s %-16s %s\n' \
    "$JOB_LABEL" "$JOB_SCHEDULE" "$rt" "$(sched_state "$JOB_LABEL")" "$(sched_health "$JOB_LABEL")" "$last$en"
done
