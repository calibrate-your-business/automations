#!/usr/bin/env bash
# bin/uninstall -- remove a job (or all) from the scheduler.
# Unloads the job (launchd bootout / systemctl disable) and deletes its unit
# file(s). Leaves the .autojob declaration and any logs untouched.
#
# Usage:
#   uninstall <label>   # e.g. uninstall com.example.nightly-report
#   uninstall all       # remove every job this framework installed (manifest)

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/lib.sh
source "$SCRIPT_DIR/lib.sh"

boot_out() {
  local label="$1"
  sched_remove "$label"
  echo "  uninstalled $label"
}

TARGET="${1:-}"
if [[ -z "$TARGET" ]]; then
  echo "usage: uninstall <label|all>" >&2
  exit 2
fi

if [[ "$TARGET" == "all" ]]; then
  if [[ ! -s "$AUTO_MANIFEST" ]]; then
    echo "automations: nothing installed (empty manifest)"
    exit 0
  fi
  while IFS= read -r label || [[ -n "$label" ]]; do
    [[ -z "$label" ]] && continue
    boot_out "$label"
  done < "$AUTO_MANIFEST"
  : > "$AUTO_MANIFEST"
  echo "automations: all jobs uninstalled"
else
  boot_out "$TARGET"
  if [[ -f "$AUTO_MANIFEST" ]]; then
    grep -vxF "$TARGET" "$AUTO_MANIFEST" > "$AUTO_MANIFEST.tmp" 2>/dev/null || true
    mv -f "$AUTO_MANIFEST.tmp" "$AUTO_MANIFEST" 2>/dev/null || true
  fi
fi
