#!/usr/bin/env bash
# pre-push guard: scratch/ never reaches main.
#
# Scratch is branch-only WIP (drafts, findings, unapproved plans). It is committed
# and pushed on `scratch`/feature branches for review, but it must NEVER land on
# main. The worktree-lifecycle skill enforces this at merge time; this hook is the
# mechanical backstop at push time (agents skip skills; a hook does not).
#
# Installed per repo at .git/hooks/pre-push (see automations bin/install-hooks).
set -u
Z=0000000000000000000000000000000000000000
blocked=0
while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/main|refs/heads/master) ;;
    *) continue ;;                                  # only guard main/master
  esac
  [ "$local_sha" = "$Z" ] && continue               # branch deletion
  if [ "$remote_sha" = "$Z" ]; then range="$local_sha"; else range="${remote_sha}..${local_sha}"; fi
  hits=$(git diff --name-only "$range" 2>/dev/null | grep '^scratch/' || true)
  if [ -n "$hits" ]; then
    echo "pre-push BLOCKED: push to $remote_ref carries scratch/ -- scratch never reaches main." >&2
    printf '%s\n' "$hits" | sed 's/^/    /' >&2
    echo "  Move that work off scratch/ (or drop it) before merging to main." >&2
    blocked=1
  fi
done
exit $blocked
