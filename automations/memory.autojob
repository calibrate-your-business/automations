# Global agent-ops: nightly Claude Code memory sync. Regenerate the capabilities
# index in the canonical memory, then CAPTURE native memory into the store and
# RESTORE the canonical memory into the slot Claude reads at session start.
LABEL=com.cyb.memory
SCHEDULE=03:05
RUNTIME=script
COMMAND=python3 agent-ops/index_capabilities.py && python3 agent-ops/memory_sync.py
WORKDIR=.
